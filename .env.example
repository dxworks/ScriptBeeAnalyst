# =============================================================================
# ScriptBeeAssistant — minimal env for `docker compose up`.
#
# Copy to .env and adjust if you like; every value has a sensible default in
# docker-compose.yml, so an empty/absent .env still boots.
#
#   $ cp .env.example .env
#   $ docker compose up --build
#   -> http://localhost:8001
#
# Single-tenant local mode: NO auth, NO Supabase, NO RLS. The data-server owns
# Postgres (DATABASE_URL) and an on-disk file store (SERIALIZED_FILES_DIR).
# =============================================================================

# --- Postgres (the `db` service) ---------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scriptbee

# --- data-server -------------------------------------------------------------
# Connection string used by the app + processor. Host `db` is the compose
# service name. Keep in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://postgres:postgres@db:5432/scriptbee

# On-disk root that replaces the Supabase 'serialized-files' bucket (a volume).
SERIALIZED_FILES_DIR=/data/serialized-files

# Max upload size in MB (mirrors the old client MAX_FILE_SIZE_MB).
MAX_UPLOAD_MB=500

# Python recursion limit for pickling deep graphs (processor).
RECURSION_LIMIT=50000

# Log verbosity for the Python services.
LOG_LEVEL=INFO
