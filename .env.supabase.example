# ===========================================
# Supabase Configuration
# ===========================================
# Copy this file to .env.supabase and fill in the keys.
# After editing, run: ./env-switch.sh
#
# Single source of truth for the Supabase URL + keys consumed by the
# web-ui (via environment.ts) and the data-server (via root .env).
# Only the local Docker stack under local_supabase_deploy/ is supported.

SUPABASE_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
JWT_SECRET=your-jwt-secret-here
