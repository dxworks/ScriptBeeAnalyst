# ===========================================
# Supabase Target Configuration
# ===========================================
# Copy this file to .env.supabase and fill in the keys.
# This is the SINGLE file to edit when switching Supabase backends.
# After editing, run: ./env-switch.sh
#
# SUPABASE_TARGET options:
#   local  = Supabase running on this laptop (localhost:8000)
#   remote = Supabase on home server via local network (192.168.0.100:8000)
#   vpn    = Supabase on home server via VPN (10.8.0.1:8000)
SUPABASE_TARGET=local

# Target URLs (change these 3 lines when switching)
# For local:
SUPABASE_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
# For remote:
# SUPABASE_URL=http://192.168.0.100:8000
# API_EXTERNAL_URL=http://192.168.0.100:8000
# SUPABASE_PUBLIC_URL=http://192.168.0.100:8000
# For vpn:
# SUPABASE_URL=http://10.8.0.1:8000
# API_EXTERNAL_URL=http://10.8.0.1:8000
# SUPABASE_PUBLIC_URL=http://10.8.0.1:8000

# Shared keys (SAME for all targets - never change these)
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
JWT_SECRET=your-jwt-secret-here
